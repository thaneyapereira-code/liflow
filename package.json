{
  "name": "liflow",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-screens": "4.26.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=@liflow/web",
    "dev:mobile": "npm run start --workspace=@liflow/mobile",
    "build:web": "npm run build --workspace=@liflow/web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.19"
  },
  "devDependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-screens": "4.26.0"
  }
}
